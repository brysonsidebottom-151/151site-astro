---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'privacy');
const p = entry?.data as any ?? {};
const sections: any[] = p.sections ?? [];
---
<Layout title={p.seo?.title ?? 'Privacy Policy | 151 Coffee'} description={p.seo?.description ?? '151 Coffee privacy policy - how we collect, use, and protect your information.'} ogImage={p.seo?.ogImage}>
  <Nav />

  <section class="page-hero" style="background-image:url('/images/background1.webp');min-height:30vh;">
    <div class="page-hero-overlay"></div>
    <div class="container">
      <div class="page-hero-content">
        <h1 data-sb-field-path="hero.heading">{p.hero?.heading ?? 'Privacy Policy'}</h1>
        <p data-sb-field-path="hero.subheading">{p.hero?.subheading ?? 'Last updated: June 2025'}</p>
      </div>
    </div>
  </section>

  <section class="legal-content">
    <div class="container" style="max-width:800px;padding:4rem 1rem;">
      {sections.map((sec: any, i: number) => (
        <div data-sb-field-path={`sections.${i}`}>
          <h2 data-sb-field-path="heading">{sec.heading}</h2>
          <p data-sb-field-path="body">{sec.body}</p>
        </div>
      ))}
    </div>
  </section>

  <Footer />
</Layout>
