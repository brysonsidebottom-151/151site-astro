---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection, getEntry } from 'astro:content';

const [locationsEntries, settingsEntry] = await Promise.all([
  getCollection('locations'),
  getEntry('settings', 'global'),
]);

const s = settingsEntry?.data as any ?? {};
const locations = locationsEntries
  .map(e => e.data as any)
  .sort((a, b) => (a.displayOrder ?? 99) - (b.displayOrder ?? 99));

const storesJson = JSON.stringify(locations.map((l) => ({
  name: l.name, address: l.address, city: l.city, state: l.state, zip: l.zip, lat: l.lat, lng: l.lng,
})));

// Group locations by state for the cards grid
const byState: Record<string, typeof locations> = {};
for (const loc of locations) {
  const key = loc.state ?? 'Other';
  if (!byState[key]) byState[key] = [];
  byState[key].push(loc);
}
const STATE_NAMES: Record<string, string> = { TX: 'Texas', KS: 'Kansas' };
---
<Layout
  title="151 Coffee Locations | Find a Drive-Thru Near You"
  description="Find your nearest 151 Coffee drive-thru. 15+ locations across Texas and Kansas with more opening soon."
  ogImage="https://www.151coffee.com/images/store1.jpg"
>
  <fragment slot="head">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  </fragment>

  <Nav active="locations" />

  <section class="loc-hero">
    <video autoplay muted loop playsinline class="hero-bg" aria-hidden="true">
      <source src="/videos/landing_bg.mp4" type="video/mp4" />
    </video>
    <div class="loc-hero-content container">
      <h1>Find Your 151</h1>
      <p>Texas &amp; Kansas - more coming soon.</p>
      <span class="loc-count">{locations.length} Locations Open</span>
    </div>
  </section>

  <div class="loc-bg">
    <section class="loc-map-section">
      <div class="container">
        <div class="locator">
          <div class="locator__panel">
            <div class="locator__search">
              <input type="text" id="locator-search" aria-label="Search locations" placeholder="Search by city, state, or zip..." />
            </div>
            <div class="locator__list" id="locator-list"></div>
          </div>
          <div class="locator__map" id="locator-map"></div>
        </div>
      </div>
    </section>
  </div>

  <section class="loc-grid-section">
      <div class="container">
        {Object.entries(byState).map(([stateCode, locs]) => (
          <div class="loc-state-group">
            <div class="loc-state-label">
              {STATE_NAMES[stateCode] ?? stateCode} - {locs.length} Location{locs.length !== 1 ? 's' : ''}
            </div>
            <div class="loc-cards">
              {locs.map((loc) => (
                <a
                  class="loc-card"
                  href={`https://www.google.com/maps/dir/?api=1&destination=${loc.lat},${loc.lng}`}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <div class="loc-card-city">{loc.city}</div>
                  <div class="loc-card-addr">
                    {loc.address}<br />{loc.city}, {loc.state} {loc.zip}
                  </div>
                  <span class="loc-card-cta">
                    Get Directions
                    <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

  <Footer />

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
  <script define:vars={{ storesJson, hours: s.hours, phone: s.phone }} is:inline>
    window.COFFEE151_STORES = JSON.parse(storesJson);
    window.COFFEE151_LOCATOR = { hours, phone };
  </script>
  <script src="/js/locator.js" is:inline></script>
</Layout>
