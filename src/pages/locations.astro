---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroVideo from '../components/HeroVideo.astro';
import { getCollection, getEntry } from 'astro:content';

const [locationsEntries, settingsEntry, pageEntry] = await Promise.all([
  getCollection('locations'),
  getEntry('settings', 'global'),
  getEntry('pages', 'locations'),
]);

const s = settingsEntry?.data as any ?? {};
const p = pageEntry?.data as any ?? {};
const locations = locationsEntries
  .map(e => ({ slug: e.id, ...(e.data as any) }))
  .sort((a, b) => (a.displayOrder ?? 99) - (b.displayOrder ?? 99));

const storesJson = JSON.stringify(locations.map((l) => ({
  name: l.name, address: l.address, city: l.city, state: l.state, zip: l.zip, lat: l.lat, lng: l.lng,
})));

// Group locations by state for the cards grid
const byState: Record<string, typeof locations> = {};
for (const loc of locations) {
  const key = loc.state ?? 'Other';
  if (!byState[key]) byState[key] = [];
  byState[key].push(loc);
}
const STATE_NAMES: Record<string, string> = Object.fromEntries(
  (p.stateNames ?? [{ code: 'TX', name: 'Texas' }, { code: 'KS', name: 'Kansas' }])
    .filter((s: any) => s?.code)
    .map((s: any) => [s.code, s.name])
);
---
<Layout
  title={p.seo?.title ?? '151 Coffee Locations | Find a Drive-Thru Near You'}
  description={p.seo?.description ?? 'Find your nearest 151 Coffee drive-thru. 15+ locations across Texas and Kansas with more opening soon.'}
  ogImage={p.seo?.ogImage ?? 'https://www.151coffee.com/images/store1.jpg'}
>
  <fragment slot="head">
    <link rel="preconnect" href="https://unpkg.com" crossorigin />
  </fragment>

  <Nav active="locations" />

  <section class="loc-hero">
    <HeroVideo src={p.heroVideo} videoClass="hero-bg" />
    <div class="loc-hero-content container">
      <h1 data-sb-field-path="hero.heading">{p.hero?.heading ?? 'Find Your 151'}</h1>
      <p data-sb-field-path="hero.subheading">{p.hero?.subheading ?? 'Texas & Kansas - more coming soon.'}</p>
      <span class="loc-count">{locations.length} <span data-sb-field-path="hero.countSuffix">{p.hero?.countSuffix ?? 'Locations Open'}</span></span>
    </div>
  </section>

  <div class="loc-bg">
    <section class="loc-map-section">
      <div class="container">
        <div class="locator">
          <div class="locator__panel">
            <div class="locator__search">
              <input type="text" id="locator-search" aria-label="Search locations" placeholder={p.searchPlaceholder ?? 'Search by city, state, or zip...'} />
            </div>
            <div class="locator__list" id="locator-list"></div>
          </div>
          <div class="locator__map" id="locator-map"></div>
        </div>
      </div>
    </section>
  </div>

  <section class="loc-grid-section">
      <div class="container">
        {Object.entries(byState).map(([stateCode, locs]) => (
          <div class="loc-state-group">
            <div class="loc-state-label">
              {STATE_NAMES[stateCode] ?? stateCode} - {locs.length} Location{locs.length !== 1 ? 's' : ''}
            </div>
            <div class="loc-cards">
              {locs.map((loc) => (
                <a
                  class="loc-card"
                  href={`https://www.google.com/maps/dir/?api=1&destination=${loc.lat},${loc.lng}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-sb-object-id={`src/content/locations/${loc.slug}.yaml`}
                >
                  <div class="loc-card-city" data-sb-field-path="city">{loc.city}</div>
                  <div class="loc-card-addr">
                    <span data-sb-field-path="address">{loc.address}</span><br />{loc.city}, {loc.state} {loc.zip}
                  </div>
                  <span class="loc-card-cta">
                    {p.directionsLabel ?? 'Get Directions'}
                    <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

  <Footer />

  <script define:vars={{ storesJson, hours: s.hours, phone: s.phone }} is:inline>
    window.COFFEE151_STORES = JSON.parse(storesJson);
    window.COFFEE151_LOCATOR = { hours, phone };
  </script>
  <script src="/js/locator-loader.js" is:inline></script>
</Layout>
