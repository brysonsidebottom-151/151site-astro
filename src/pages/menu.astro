---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getEntry, getCollection } from 'astro:content';

const [menuEntry, drinksEntries] = await Promise.all([
  getEntry('pages', 'menu'),
  getCollection('drinks'),
]);

const p = menuEntry!.data as any;
const allDrinks = drinksEntries
  .map(e => ({ slug: e.id, ...(e.data as any) }))
  .sort((a: any, b: any) => (a.menuOrder ?? 99) - (b.menuOrder ?? 99));

// Derive categories from YAML so they're editable in Visual Editor
const CATEGORIES = (p.categories ?? []).map((cat: any) => ({
  tab: cat.slug,
  num: cat.number,
  title: cat.title,
  desc: cat.description,
}));

// Build slug map dynamically from YAML categories
const CAT_SLUG_MAP: Record<string, string> = Object.fromEntries(
  CATEGORIES.map((cat: any) => [cat.title, cat.tab])
);

function catSlug(drink: any): string {
  return CAT_SLUG_MAP[drink.category] ?? drink.category?.toLowerCase().replace(/\s+/g, '') ?? '';
}

// Build DRINKS data object for flavor filter JS
const drinksDataObj: Record<string, { tags: string[]; catSlug: string }> = {};
for (const d of allDrinks) {
  drinksDataObj[d.slug] = { tags: d.tags ?? [], catSlug: catSlug(d) };
}

const dirtypopSodas: string[] = (p.dirtypopExtra ?? '')
  .split(',').map((s: string) => s.trim()).filter(Boolean);

const KIDS_ICONS: Record<string, string> = {
  'kids-hot-cocoa': '☕', 'kids-chocolate-milk': '🥛', 'kids-apple-juice': '🧃', 'kids-hot-cider': '🍎',
};
const HOTFOOD_ICONS: Record<string, string> = {
  'hotfood-chorizo-burrito': '🌯', 'hotfood-ultimate-burrito': '🌯', 'hotfood-everything-bagel': '🥯',
  'hotfood-maple-waffle': '🧇', 'hotfood-jalapeno-biscuit': '🥐', 'hotfood-sticky-bun-coffee-cake': '🍰',
  'hotfood-egg-white-frittata': '🥚', 'hotfood-bacon-cheddar-egg-bites': '🥚',
};
const TREATS_ICONS: Record<string, string> = {
  'treats-sea-salt-chocolate-chip': '🍪', 'treats-peanut-butter': '🍪', 'treats-snickerdoodle': '🍪',
  'treats-hippie-gf-cookie': '🌿', 'treats-whookie-gf-cookie': '🖤', 'treats-banana-walnut-bread': '🍌',
  'treats-pumpkin-spice-bread': '🎃', 'treats-lemon-pound-cake': '🍋', 'treats-cinnamon-chip-crumbcake': '🧁',
  'treats-blueberry-lemon-muffin-top': '🫐', 'treats-cake-pops': '🍭',
};

function isIconCat(slug: string) { return ['kids','hotfood','treats'].includes(slug); }
function getIcon(slug: string, cat: string) {
  if (cat === 'kids') return KIDS_ICONS[slug] ?? '🧃';
  if (cat === 'hotfood') return HOTFOOD_ICONS[slug] ?? '🍽';
  if (cat === 'treats') return TREATS_ICONS[slug] ?? '🍪';
  return '';
}

const drinksJson = JSON.stringify(drinksDataObj);

const milks: string[] = p.customize?.milks ?? [];
const flavors: string[] = p.customize?.flavors ?? [];
const sfFlavors: string[] = p.customize?.sfFlavors ?? [];
---
<Layout title={p.seo?.title ?? 'Menu | 151 Coffee - Coffee, Cold Brew, Energy & Dirty Pop'} description={p.seo?.description ?? 'Explore the full 151 Coffee menu. Signature espresso drinks, cold brew, blended energy, Dirty Pop sodas, refreshers, smoothies, teas, and more.'} ogImage={p.seo?.ogImage}>
  <Fragment slot="head">
    <link rel="stylesheet" href="/menu.css" />
  </Fragment>

  <Nav active="menu" />

  <section class="menu-hero">
    <video autoplay muted loop playsinline class="hero-bg" aria-hidden="true">
      <source src="/videos/landing_bg.mp4" type="video/mp4" />
    </video>
    <div class="menu-hero-content">
      <h1 data-sb-field-path="hero.heading">{p.hero?.heading ?? 'Our Menu'}</h1>
      <p data-sb-field-path="hero.subheading">{p.hero?.subheading ?? 'Thousands of flavor combinations. One perfect drink, every time.'}</p>
    </div>
    <div class="cat-nav" id="catNav">
      <div class="cat-nav-inner">
        {CATEGORIES.map((cat: any, i: number) => (
          <button class={`cat-link${i === 0 ? ' active' : ''}`} data-tab={cat.tab}
            data-sb-field-path={`categories.${i}.title`}>{cat.title}</button>
        ))}
      </div>
    </div>
  </section>

  <section class="timeline-wrap">
    <div class="timeline-scroll" id="timelineScroll">
      {CATEGORIES.map((cat: any, catIndex: number) => {
        const drinks = allDrinks.filter((d: any) => catSlug(d) === cat.tab);
        return (
          <>
            <div class="cat-title-card" id={`cat-${cat.tab}`} data-cat={cat.tab}
              data-sb-field-path={`categories.${catIndex}`}>
              <div class="cat-title-inner">
                <span class="cat-num" data-sb-field-path="number">{cat.num}</span>
                <h2 class="cat-title-text" data-sb-field-path="title">{cat.title}</h2>
                <p class="cat-title-desc" data-sb-field-path="description">{cat.desc}</p>
                <svg class="cat-arrow" viewBox="0 0 40 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2 12h36M26 2l12 10-12 10" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
            {drinks.map((drink: any) => (
              <a class={`drink-card${drink.slug === 'coldbrew-nitro-brew' ? ' nitro-card' : ''}`}
                data-cat={cat.tab} href={`/drinks/${drink.slug}`}
                data-sb-object-id={`src/content/drinks/${drink.slug}.yaml`}>
                <div class={`drink-img-wrap${isIconCat(cat.tab) ? ' kids-img-wrap' : ''}`}>
                  {isIconCat(cat.tab)
                    ? <span class="kids-icon">{drink.icon || getIcon(drink.slug, cat.tab)}</span>
                    : drink.image
                      ? <img loading="lazy" decoding="async" src={drink.image.startsWith('/') ? drink.image : '/' + drink.image} alt={drink.name} data-sb-field-path="image" />
                      : <img loading="lazy" decoding="async" src="/images/drinks/energy/151 Blue Energy Hand (1).png" alt={drink.name} data-sb-field-path="image" />
                  }
                </div>
                <div class="drink-info">
                  <h3 data-sb-field-path="name">{drink.name}</h3>
                  {drink.subtitle && <p data-sb-field-path="subtitle">{drink.subtitle}</p>}
                </div>
              </a>
            ))}
            {cat.tab === 'dirtypop' && (
              <div class="soda-timeline-card" data-cat="dirtypop">
                <p class="soda-also" data-sb-field-path="labels.sodaAlso">{p.labels?.sodaAlso ?? 'Also available plain:'}</p>
                <div class="soda-list" data-sb-field-path="dirtypopExtra">
                  {dirtypopSodas.map((s: string) => <span>{s}</span>)}
                </div>
              </div>
            )}
          </>
        );
      })}

      <div class="timeline-empty-state" id="timelineEmpty">
        <p data-sb-field-path="labels.emptyHeading">{p.labels?.emptyHeading ?? 'Nothing here yet.'}</p>
        <span data-sb-field-path="labels.emptySub">{p.labels?.emptySub ?? "But we're always working on something good."}</span>
      </div>
      <div class="timeline-end-spacer"></div>
    </div>
  </section>

  <section class="customize-section">
    <div class="cz-inner">
      <div class="cz-heading">
        <h2 data-sb-field-path="customize.heading">{p.customize?.heading ?? 'Customize Your Drink, Your Way'}</h2>
        <p class="cz-filter-hint" id="czFilterHint" aria-live="polite"></p>
      </div>
      <div class="cz-layout">
        <div class="cz-right" style="width:100%;max-width:100%;flex:1">
          <div class="cz-block">
            <p class="cz-label"><span data-sb-field-path="customize.flavorLabel">{p.customize?.flavorLabel ?? 'Add a Flavor'}</span> <span class="cz-filter-tip" data-sb-field-path="customize.flavorTip">{p.customize?.flavorTip ?? '- tap to filter the menu'}</span></p>
            <div class="cz-pills cz-pills--flavors" id="czFlavorPills" data-sb-field-path="customize.flavors">
              {flavors.map((f: string, i: number) => (
                <span class="cpill cpill--filter" data-flavor={f} data-sb-field-path={`.${i}`}>{f}</span>
              ))}
            </div>
          </div>
          <div class="cz-block cz-block--sf">
            <p class="cz-label cz-label--sf" data-sb-field-path="customize.sfLabel">{p.customize?.sfLabel ?? 'Also Available Sugar Free'}</p>
            <div class="cz-pills cz-pills--flavors" data-sb-field-path="customize.sfFlavors">
              {sfFlavors.map((f: string, i: number) => (
                <span class="cpill cpill--sf cpill--filter" data-flavor={f} data-sb-field-path={`.${i}`}>{f}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <script define:vars={{ drinksJson }} is:inline>
    window.DRINKS = JSON.parse(drinksJson);
  </script>
  <script is:inline>
  (function () {
    var scroll = document.getElementById('timelineScroll');
    var catLinks = document.querySelectorAll('.cat-link');
    var titleCards = document.querySelectorAll('.cat-title-card');

    function equalizeCards() {
      var cards = scroll.querySelectorAll('.drink-card');
      cards.forEach(function(c) { c.style.width = ''; c.style.minWidth = ''; });
      var maxW = 0;
      cards.forEach(function(c) { if (c.offsetWidth > maxW) maxW = c.offsetWidth; });
      if (maxW > 0) cards.forEach(function(c) { c.style.width = maxW + 'px'; c.style.minWidth = maxW + 'px'; });
    }
    window.addEventListener('load', equalizeCards);
    window.addEventListener('resize', equalizeCards);

    function getActiveCat() {
      var threshold = scroll.getBoundingClientRect().width * 0.35;
      var active = null;
      titleCards.forEach(function(card) {
        var left = card.offsetLeft - scroll.scrollLeft;
        if (left <= threshold) active = card.dataset.cat;
      });
      return active || (titleCards[0] && titleCards[0].dataset.cat);
    }
    function applyActiveCat(cat) {
      catLinks.forEach(function(btn) { btn.classList.toggle('active', btn.dataset.tab === cat); });
      scroll.querySelectorAll('[data-cat]').forEach(function(el) { el.classList.toggle('cat-active', el.dataset.cat === cat); });
    }
    scroll.addEventListener('scroll', function() { applyActiveCat(getActiveCat()); }, { passive: true });
    applyActiveCat('coffee');

    catLinks.forEach(function(btn) {
      btn.addEventListener('click', function() {
        stopAutoScroll();
        var target = document.getElementById('cat-' + btn.dataset.tab);
        if (!target) return;
        scroll.scrollTo({ left: target.offsetLeft - 24, behavior: 'smooth' });
      });
    });

    var rafId = null;
    var autoScrollStopped = false;
    var SCROLL_SPEED = 0.6;
    function autoScroll() {
      if (autoScrollStopped) return;
      scroll.scrollLeft += SCROLL_SPEED;
      rafId = requestAnimationFrame(autoScroll);
    }
    function stopAutoScroll() {
      autoScrollStopped = true;
      if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
    }
    ['wheel','mousedown','touchstart'].forEach(function(evt) { scroll.addEventListener(evt, stopAutoScroll, { once: true, passive: true }); });
    rafId = requestAnimationFrame(autoScroll);
    setTimeout(function() { scroll.classList.add('timeline-ready'); }, 80);

    scroll.addEventListener('wheel', function(e) {
      if (Math.abs(e.deltaY) > Math.abs(e.deltaX)) { e.preventDefault(); scroll.scrollLeft += e.deltaY * 3; }
    }, { passive: false });

    var paramTab = (window.location.hash || '').replace(/^#/, '') || new URLSearchParams(window.location.search).get('tab');
    if (paramTab && document.getElementById('cat-' + paramTab)) {
      window.addEventListener('load', function() {
        stopAutoScroll(); equalizeCards();
        scroll.scrollTo({ left: document.getElementById('cat-' + paramTab).offsetLeft - 24, behavior: 'instant' });
        applyActiveCat(paramTab);
      });
    }

    var activeFilter = null;
    var filterHint = document.getElementById('czFilterHint');
    var emptyState = document.getElementById('timelineEmpty');
    var sodaCard = scroll.querySelector('.soda-timeline-card');

    function animateOut(el) {
      el.classList.remove('filter-animating-in'); el.classList.add('filter-animating-out');
      setTimeout(function() { el.classList.remove('filter-animating-out'); el.style.display = 'none'; }, 180);
    }
    function animateIn(el, delay) {
      el.style.display = ''; el.classList.remove('filter-animating-out','filter-animating-in');
      void el.offsetWidth; el.style.animationDelay = (delay || 0) + 'ms';
      el.classList.add('filter-animating-in');
      el.addEventListener('animationend', function() { el.classList.remove('filter-animating-in'); el.style.animationDelay = ''; }, { once: true });
    }
    var timelineWrap = document.querySelector('.timeline-wrap');

    function applyFilter(flavor) {
      var drinkCards = Array.from(scroll.querySelectorAll('a.drink-card'));
      var tCards = Array.from(scroll.querySelectorAll('.cat-title-card'));
      if (!flavor) {
        scroll.classList.remove('has-filter');
        if (sodaCard) animateIn(sodaCard, 0);
        if (emptyState) emptyState.classList.remove('visible');
        document.querySelectorAll('.cpill--filter').forEach(function(p) { p.classList.remove('cpill--active'); });
        if (filterHint) filterHint.textContent = '';
        var mi = 0;
        tCards.forEach(function(card) { animateIn(card, mi++ * 30); });
        drinkCards.forEach(function(card) { animateIn(card, mi++ * 18); });
        setTimeout(function() { if (timelineWrap) timelineWrap.style.minHeight = ''; scroll.style.minHeight = ''; }, 600);
        return;
      }
      if (timelineWrap) timelineWrap.style.minHeight = timelineWrap.offsetHeight + 'px';
      scroll.style.minHeight = scroll.offsetHeight + 'px';
      scroll.classList.add('has-filter');
      if (sodaCard) animateOut(sodaCard);
      var matchedCats = new Set();
      drinkCards.forEach(function(card) {
        var id = (card.getAttribute('href') || '').replace('/drinks/', '');
        var drink = DRINKS[id];
        if (drink && drink.tags && drink.tags.includes(flavor)) matchedCats.add(drink.catSlug);
      });
      tCards.forEach(function(card) { animateOut(card); });
      drinkCards.forEach(function(card) { animateOut(card); });
      setTimeout(function() {
        tCards.forEach(function(card) { if (matchedCats.has(card.dataset.cat)) animateIn(card, 0); });
        var mi2 = 0;
        drinkCards.forEach(function(card) {
          var id = (card.getAttribute('href') || '').replace('/drinks/', '');
          var drink = DRINKS[id];
          if (drink && drink.tags && drink.tags.includes(flavor)) animateIn(card, mi2++ * 45);
        });
        if (emptyState) emptyState.classList.toggle('visible', matchedCats.size === 0);
      }, 200);
      if (filterHint) filterHint.textContent = 'Showing drinks with: ' + flavor + ' - tap again to clear';
    }

    document.querySelectorAll('.cpill--filter').forEach(function(pill) {
      pill.addEventListener('click', function() {
        var flavor = pill.dataset.flavor;
        if (activeFilter === flavor) { activeFilter = null; applyFilter(null); }
        else {
          activeFilter = flavor;
          document.querySelectorAll('.cpill--filter').forEach(function(p) { p.classList.remove('cpill--active'); });
          document.querySelectorAll('.cpill--filter[data-flavor="' + flavor + '"]').forEach(function(p) { p.classList.add('cpill--active'); });
          applyFilter(flavor);
          document.querySelector('.timeline-wrap').scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  })();
  </script>
</Layout>
