---
import { getEntry } from 'astro:content';
interface Props {
  active?: string;
}
const { active = '' } = Astro.props;
const g = await getEntry('settings', 'global');
const s = g?.data as any ?? {};
const siteName = s.siteName ?? '151 Coffee';
const logo = s.logo ?? '/images/logo.png';
---
<div id="top"></div>
<div class="loading-bar"></div>
<nav>
  <div class="nav-container">
    <a href="/" class="logo" data-sb-object-id="src/content/settings/global.yaml">
      <img src={logo} alt={`${siteName} logo`} style="width:3rem;height:auto;" data-sb-field-path="logo" />
      <span data-sb-field-path="siteName">{siteName}</span>
    </a>
    <ul class="nav-links">
      <li><a href="/menu" class={`nav-link${active==='menu'?' active':''}`}>Menu</a></li>
      <li><a href="/locations" class={`nav-link${active==='locations'?' active':''}`}>Locations</a></li>
      <li><a href="/about" class={`nav-link${active==='about'?' active':''}`}>About</a></li>
      <li><a href="/careers" class={`nav-link${active==='careers'?' active':''}`}>Careers</a></li>
      <li><a href="/#contact" class="nav-link">Contact</a></li>
      <li><a href="/realestate" class={`nav-link${active==='realestate'?' active':''}`}>Real Estate</a></li>
      <li><a id="giftCardMobileBtn" href="javascript:void(0);" class="nav-link">Gift Card</a></li>
    </ul>
    <a id="giftCardNavBtn" href="javascript:void(0);" class="main-menu-btn">Gift Card</a>
    <div class="menu-toggle" role="button" tabindex="0" aria-label="Toggle navigation menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </div>
  </div>
</nav>
