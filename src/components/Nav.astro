---
import { getEntry } from 'astro:content';
interface Props {
  active?: string;
}
const { active = '' } = Astro.props;
const g = await getEntry('settings', 'global');
const s = g?.data as any ?? {};
const siteName = s.siteName ?? '151 Coffee';
const logo = s.logo ?? '/images/logo.png';
const giftCardLabel = s.giftCardLabel ?? 'Gift Card';

const navLinks: { label: string; href: string }[] = s.nav ?? [
  { label: 'Menu', href: '/menu' },
  { label: 'Locations', href: '/locations' },
  { label: 'About', href: '/about' },
  { label: 'Careers', href: '/careers' },
  { label: 'Contact', href: '/#contact' },
  { label: 'Real Estate', href: '/realestate' },
];

const cur = Astro.url.pathname.replace(/\/+$/, '') || '/';
function isActive(href: string): boolean {
  const base = (href.split('#')[0] || '').replace(/\/+$/, '');
  if (!base || base === '/') return false;
  const key = base.replace(/^\//, '');
  if (active && active === key) return true;
  return cur === base || cur.startsWith(base + '/');
}
---
<div id="top"></div>
<div class="loading-bar"></div>
<nav>
  <div class="nav-container">
    <a href="/" class="logo" data-sb-object-id="src/content/settings/global.yaml">
      <img src={logo} alt={`${siteName} logo`} style="width:3rem;height:auto;" data-sb-field-path="logo" />
      <span data-sb-field-path="siteName">{siteName}</span>
    </a>
    <ul class="nav-links" data-sb-object-id="src/content/settings/global.yaml">
      {navLinks.map((link, i) => (
        <li><a href={link.href} class={`nav-link${isActive(link.href) ? ' active' : ''}`} data-sb-field-path={`nav.${i}.label`}>{link.label}</a></li>
      ))}
    </ul>
    <button type="button" id="giftCardNavBtn" class="main-menu-btn" data-sb-object-id="src/content/settings/global.yaml" data-sb-field-path="giftCardLabel">{giftCardLabel}</button>
    <div class="menu-toggle" role="button" tabindex="0" aria-label="Toggle navigation menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </div>
  </div>
</nav>
